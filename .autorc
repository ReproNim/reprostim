{
    "onlyPublishWithReleaseLabel": true,
    "baseBranch": "master",
    "author": "ReproNim Team[bot] <info@repronim.org>",
    "noVersionPrefix": true,
    "plugins": [
        "git-tag",
        [
            "exec",
            {
                  "beforeRelease": "bash tools/ci/release_reprostim_zenodo.sh && git add .zenodo.json",
                  "afterRelease": "python -m build && twine upload dist/* && bash tools/ci/release_reprostim_docker.sh"
            }
        ],
        "released"
    ]
}
